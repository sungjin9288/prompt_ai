{
  "manifest_version": 3,
  "name": "Prompt AI Studio Refine",
  "version": "0.4.0",
  "description": "Send selected browser text to Prompt AI Studio and receive a review-required target AI handoff package.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Prompt AI Studio Refine",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content/adapters.js", "content/inpage.js"],
      "css": ["content/inpage.css"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*"
  ],
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "storage"
  ]
}
